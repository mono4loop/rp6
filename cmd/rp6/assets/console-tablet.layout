// RP6 "tablet" layout — the fixed layout for large touch screens (Android
// tablets, e.g. the OnePlus Pad 3 in resolutions.txt). Selected whenever the
// platform is mobile AND the screen is tablet-class (isTabletSize); it is NOT
// gated on the console/fullscreen intent — a tablet always gets this layout. It
// must be parsed BEFORE the desktop `console` variant so it wins (see
// layoutSource — this file is concatenated first).
//
// The pad-rack "store" selector needs room, so this variant gives the sample-pak
// selector its own left rail beside a single centre column that stacks the
// sequencer over the pads. The transport (TEMPO) carries the VU strip on its
// right, and the FX rack is hidden (kept off unless the user turns it on).
//
//   ┌───────┬─────────────────────────────┐
//   │       │ transport | vu (strip)      │
//   │       ├─────────────────────────────┤
//   │ paks  │            seq              │
//   │       │─────────────────────────────│
//   │       │            pads             │
//   │       ├─────────────────────────────┤
//   │       │            keyboard         │
//   │       │            status           │
//   └───────┴─────────────────────────────┘

layout tablet when mobile && tablet {
  Border {
    bottom: VBox {
      fx(show: false)
      keysfx(show: false) if !p6_active
      keys(show: true)
      toggles
      status
    }

    // Full-width top: the transport (TEMPO) with the VU meter as a horizontal
    // strip filling the space to its right, and — when the P-6 is the active
    // backend — its hardware rack below. On a tablet the backend is normally the
    // emulator, so `p6` is usually absent here.
    top: VBox {
      Border {
        left: transport
        center: vu(orientation: horizontal)
      }
      p6 if p6_active
    }

    // Left rail: the sample-pak selector, filling the tall rail to the left of
    // the pad/sequencer column (on by default in the console).
    left: paks(show: true)

    // Centre column: the sequencer on top, the pads stacked underneath it.
    center: Split {
      horizontal: false
      offset: 0.5
      leading: seq(tracks: 6) if !seq_docked
      trailing: pads(layout: paged) if pads_visible
    }
  }
}
