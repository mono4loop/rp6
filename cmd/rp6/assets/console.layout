// RP6 "mixing console" layout — the fixed desktop full-screen layout (press F11
// or Ctrl+Shift+Enter, or the bottom-bar CONSOLE toggle, to enter/leave).
//
// Selected `when fullscreen && desktop`: mobile devices use the phone/tablet
// layouts instead (a tablet gets the dedicated `tablet` variant, which is parsed
// first). The loader concatenates the layout files with the tablet variant FIRST,
// then this console, then the default file's `phone`/`window` variants, so the
// first matching guard wins. It shares the `rack …` blocks defined in
// default.layout.
//
//   ┌───────┬───────────────────────┬───────┐
//   │ trans │                        │       │
//   │  vu   │                        │  seq  │   right rail when undocked
//   │ paks  │        pads            │       │
//   │  fx   │                        │       │
//   │  vu   │                        │       │
//   ├───────┴───────────────────────┴───────┤
//   │                status                 │
//   └───────────────────────────────────────┘

layout console when fullscreen && desktop {
  Border {
    // Bottom: the P-6-only rack (full width, only when the P-6 is active), or the
    // emulator's host-side Keys FX rack, above the keyboard (full width, on by
    // default in the console, and twice as tall) and a full-width status bar.
    bottom: VBox {
      p6 if p6_active
      keysfx(show: true) if !p6_active
      keys(show: true)
      toggles
      status
    }

    // Left rail: transport + the VU meter (horizontal strip) on top, the
    // sample-pak selector filling the middle, and pad FX at the bottom. Keeping
    // FX here avoids reserving an otherwise-empty full-height right rail when
    // the sequencer is docked in the centre split.
    left: Border {
      top: VBox {
        transport
        vu(orientation: horizontal)
      }
      center: paks(show: true)
      bottom: fx(show: true)
    }

    // Right rail: the recorder (looper) on top — placed but off by default so it
    // doesn't crowd the console; toggle it on with the REC button — and the
    // sequencer below it when it is not docked in the centre split.
    right: VBox {
      rec
      seq(show: true, tracks: 6) if !seq_docked
    }

    // Centre: the pads fill the space; when the sequencer is docked it shares
    // the centre as the right pane of a split.
    center: Split {
      horizontal: true
      // Keep enough width for 16 touchable sequencer steps on a 1920px laptop
      // while the six-column pad grid remains comfortably finger-sized.
      offset: 0.517
      leading: pads(layout: paged) if pads_visible
      trailing: seq(show: true, tracks: 6) if seq_docked
    }
  }
}
