// RP6 "mixing console" layout — used when the window is full screen (press F11
// or Ctrl+Shift+Enter to toggle full screen).
//
// Compiled into the binary alongside default.layout; the loader concatenates the
// two with this file FIRST, so this `when fullscreen` variant takes precedence
// over the default/original variants. It shares the `rack …` blocks defined in
// default.layout.
//
//   ┌───────┬───────────────────────┬───────┐
//   │ trans │                        │       │
//   │  vu   │                        │  seq  │   right rail when undocked
//   │ paks  │        pads            │       │
//   │  fx   │                        │       │
//   │  vu   │                        │       │
//   ├───────┴───────────────────────┴───────┤
//   │                status                 │
//   └───────────────────────────────────────┘

layout console when fullscreen {
  Border {
    // Bottom: the P-6-only rack (full width, only when the P-6 is active), or the
    // emulator's host-side Keys FX rack, above the keyboard (full width, on by
    // default in the console, and twice as tall) and a full-width status bar.
    bottom: VBox {
      p6 if p6_active
      keysfx(show: true) if !p6_active
      keys(show: true)
      toggles
      status
    }

    // Left rail: transport + the VU meter (horizontal strip) on top, the
    // sample-pak selector filling the middle, and pad FX at the bottom. Keeping
    // FX here avoids reserving an otherwise-empty full-height right rail when
    // the sequencer is docked in the centre split.
    left: Border {
      top: VBox {
        transport
        vu(orientation: horizontal)
      }
      center: paks(show: true)
      bottom: fx(show: true)
    }

    // Right rail: the sequencer only when it is not docked in the centre split.
    // When docked this region disappears completely, giving that width back to
    // the pads and sequencer rather than leaving a mostly-empty FX column.
    right: seq if !seq_docked

    // Centre: the pads fill the space; when the sequencer is docked it shares
    // the centre as the right pane of a split.
    center: Split {
      horizontal: true
      // Keep enough width for 16 touchable sequencer steps on a 1920px laptop
      // while the six-column pad grid remains comfortably finger-sized.
      offset: 0.58
      leading: pads if pads_visible
      trailing: seq if seq_docked
    }
  }
}
