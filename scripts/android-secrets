#!/usr/bin/env bash
# android-secrets — set the GitHub Actions secrets (and optional variables) that
# the Android release workflow (.github/workflows/android.yml) needs to sign the
# APK, from a signing keystore, using the GitHub CLI (gh).
#
# It sets these repo secrets so CI signs with the SAME key you use locally:
#   ANDROID_KEYSTORE_BASE64    base64 of the keystore file
#   ANDROID_KEYSTORE_PASSWORD  keystore (store) password
#   ANDROID_KEY_PASSWORD       key password
#   ANDROID_KEY_ALIAS          key alias
#
# Usage:
#   scripts/android-secrets [-R owner/repo] <keystore>
#
# Passwords/alias are read from the environment if set, else prompted:
#   KEY_ALIAS  (default: rp6)
#   STOREPASS  (prompted, hidden, if unset)
#   KEYPASS    (prompted; empty = same as STOREPASS)
#
# Optionally also set the workflow's Actions *variables* by exporting them:
#   ANDROID_ABI=android            scripts/android-secrets my.keystore   # universal APK
#   ANDROID_NDK_VERSION=27.2.12479018 scripts/android-secrets my.keystore
#
# Requires: gh (authenticated: gh auth login), and keytool for verification.
set -euo pipefail

repo_flag=()
while getopts "R:h" opt; do
	case "$opt" in
	R) repo_flag=(--repo "$OPTARG") ;;
	h)
		sed -n '2,30p' "$0" | sed 's/^# \{0,1\}//'
		exit 0
		;;
	*) exit 2 ;;
	esac
done
shift $((OPTIND - 1))

ks="${1:-}"
[ -n "$ks" ] || {
	echo "usage: $0 [-R owner/repo] <keystore>" >&2
	exit 2
}
[ -f "$ks" ] || {
	echo "error: keystore not found: $ks" >&2
	exit 1
}

command -v gh >/dev/null 2>&1 || {
	echo "error: gh (GitHub CLI) not found — https://cli.github.com" >&2
	exit 1
}
gh auth status >/dev/null 2>&1 || {
	echo "error: not logged in to gh (run: gh auth login)" >&2
	exit 1
}

alias="${KEY_ALIAS:-rp6}"
storepass="${STOREPASS:-}"
keypass="${KEYPASS:-}"
if [ -z "$storepass" ]; then
	read -rsp "keystore (store) password: " storepass
	echo
fi
if [ -z "$keypass" ]; then
	read -rsp "key password [enter = same as store]: " keypass
	echo
	keypass="${keypass:-$storepass}"
fi

# Verify the store password + alias against the keystore (best effort).
if command -v keytool >/dev/null 2>&1; then
	if ! keytool -list -keystore "$ks" -alias "$alias" -storepass "$storepass" >/dev/null 2>&1; then
		echo "error: keytool couldn't read alias '$alias' with the given store password" >&2
		echo "       check KEY_ALIAS and the store password" >&2
		exit 1
	fi
fi

target="$(gh repo view "${repo_flag[@]}" --json nameWithOwner -q .nameWithOwner 2>/dev/null || echo 'the current repo')"
echo "setting Android signing secrets on ${target}…"

# stdin (piped, no trailing newline) keeps the values out of the process args.
base64 <"$ks" | tr -d '\n' | gh secret set "${repo_flag[@]}" ANDROID_KEYSTORE_BASE64
printf '%s' "$storepass" | gh secret set "${repo_flag[@]}" ANDROID_KEYSTORE_PASSWORD
printf '%s' "$keypass" | gh secret set "${repo_flag[@]}" ANDROID_KEY_PASSWORD
printf '%s' "$alias" | gh secret set "${repo_flag[@]}" ANDROID_KEY_ALIAS

echo "  set secrets: ANDROID_KEYSTORE_BASE64, ANDROID_KEYSTORE_PASSWORD, ANDROID_KEY_PASSWORD, ANDROID_KEY_ALIAS"

# Optional Actions variables (the workflow reads these with fallbacks).
if [ -n "${ANDROID_ABI:-}" ]; then
	printf '%s' "$ANDROID_ABI" | gh variable set "${repo_flag[@]}" ANDROID_ABI
	echo "  set variable ANDROID_ABI=$ANDROID_ABI"
fi
if [ -n "${ANDROID_NDK_VERSION:-}" ]; then
	printf '%s' "$ANDROID_NDK_VERSION" | gh variable set "${repo_flag[@]}" ANDROID_NDK_VERSION
	echo "  set variable ANDROID_NDK_VERSION=$ANDROID_NDK_VERSION"
fi

echo "done — push a v* tag to build a signed APK with this key."
